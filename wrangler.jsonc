{
  "name": "airiskweb",
  "compatibility_date": "2026-07-07",
  "assets": {
    "directory": "./domain-dist",
    "not_found_handling": "single-page-application"
  }
  // domain routing is handled by a manual zone-level Workers Route (airiskweb.com/* -> this worker),
  // set up directly in the Cloudflare dashboard — NOT by wrangler's own custom_domain feature (that
  // needs DNS write access the deploy token doesn't have). Do not re-add a "routes" block here.
}
